package models

// Row представляет одну строку таблицы истинности
type Row struct {
	Values map[string]bool
	Result bool
	Index  int // Десятичный индекс набора (например, 0 для 000, 7 для 111)
}

// Term используется для минимизации (представляет конъюнкцию переменных)
type Term struct {
	Mask    int   // Маска присутствующих переменных (1 - есть, 0 - нет)
	Value   int   // Значения переменных (1 - без инверсии, 0 - с инверсией)
	Indices []int // Индексы наборов, которые покрывает данная импликанта
}
